# Drell-Yan (pp -> e+ e-) at leading order, forced through Amegic.
#
# Purpose: exercise the Amegic runtime-compilation path (write process
# source -> ./makelibs -> reload), which the default CI/LO_Z example does
# NOT, because it runs through Comix. Unlike the bundled Amegic examples,
# this stays at LO (Order (*,2)) so it needs no external one-loop provider
# (BlackHat/OpenLoops) and is otherwise self-contained.
(run){
  EVENTS 100;
  ME_SIGNAL_GENERATOR Amegic;    # force process-library generation + compile
}(run)

(beam){
  BEAM_1 = 2212; BEAM_ENERGY_1 = 7000
  BEAM_2 = 2212; BEAM_ENERGY_2 = 7000
}(beam)

(processes){
  Process 93 93 -> 11 -11
  Order (*,2)
  Integration_Error 0.05
  End process
}(processes)

(selector){
  Mass 11 -11 66 166
}(selector)
