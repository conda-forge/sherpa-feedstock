From f3c82e7f1f18da5b117329e8d9d1cca3eb3340ec Mon Sep 17 00:00:00 2001
From: Matthew Feickert <matthew.feickert@cern.ch>
Date: Tue, 16 Jun 2026 23:47:34 -0600
Subject: [PATCH] FIX: remove null characters for prefix replacement

At build time conda uses a long environment name (the placeholder strings) so
that hardcoded strings inside binaries are long, then at install time replaces
the build prefix with the (shorter) install prefix, padding the remainder with
NUL bytes. C strings terminate at the first NUL, but C++ std::string keeps them,
so a concatenation like '$PREFIX/lib/SHERPA-MC' + '/libSherpaSM.so' becomes
'$CONDA_PREFIX/lib/SHERPA-MC/\x00...\x00/libSherpaSM.so'. Stripping NULs from
Run_Parameter::Gen::Variable yields the intended path.

Co-authored-by: Chris Burr <chrisburr@users.noreply.github.com>
---
 ATOOLS/Org/Run_Parameter.C | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/ATOOLS/Org/Run_Parameter.C b/ATOOLS/Org/Run_Parameter.C
index c9b3c829f..25ecf5feb 100644
--- a/ATOOLS/Org/Run_Parameter.C
+++ b/ATOOLS/Org/Run_Parameter.C
@@ -1,3 +1,4 @@
+#include <algorithm>
 #include <iostream>
 #include "ATOOLS/Org/Run_Parameter.H"
 #include "ATOOLS/Math/MathTools.H"
@@ -454,7 +455,10 @@ std::string Run_Parameter::Gen::Variable(const std::string &key)
           "Runtime parameter \"" + key
           + "\" not registered and no default given to fall back on");
   }
-  return it->second;
+  std::string str = it->second;
+  // remove all null characters anywhere in string
+  str.erase(std::remove(str.begin(), str.end(), '\0'), str.end());
+  return str;
 }
 
 void Run_Parameter::Gen::PrintGitVersion(std::ostream &str,
